{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.jpeg",
      "use": "@vercel/static"
    },
    {
      "src": "eventos.php",
      "use": "vercel-php@0.7.1",
      "config": {
        "includeFiles": "system/config.php"
      }
    },
    {
      "src": "system/**/*.php",
      "use": "vercel-php@0.7.1",
      "config": {
        "includeFiles": "system/**"
      }
    },
    {
      "src": "system/**/*.{css,js}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/eventos\\.php", "dest": "/eventos.php" },
    { "src": "/system/(.*\\.php)", "dest": "/system/$1" },
    { "src": "/system/(.*\\.css)", "dest": "/system/$1" },
    { "src": "/system/(.*\\.js)", "dest": "/system/$1" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/(.*\\.css)", "dest": "/$1" },
    { "src": "/(.*\\.jpeg)", "dest": "/$1" },
    { "src": "/", "dest": "/index.html" }
  ]
}
